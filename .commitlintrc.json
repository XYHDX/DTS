{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "docs", "style", "refactor", "test",
       "chore", "perf", "build", "ci", "revert", "security", "deps"]
    ],
    "subject-case": [0],
    "subject-empty": [2, "never"],
    "header-max-length": [2, "always", 100]
  }
}
