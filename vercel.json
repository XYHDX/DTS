{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "api/test.py",  "use": "@vercel/python" },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/test",     "dest": "/api/test.py" },
    { "src": "/api/(.*)",     "dest": "/api/index.py" },
    { "src": "/dashboard/?",  "dest": "/public/index.html" },
    { "src": "/(.*)",         "dest": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "0" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(self), microphone=(), geolocation=(self), payment=(), interest-cohort=()" },
        { "key": "Cross-Origin-Opener-Policy",  "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy","value": "same-site" }
      ]
    },
    {
      "source": "/(dashboard|admin|driver|passenger)(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https://*.tile.openstreetmap.org https://tile.openstreetmap.org; connect-src 'self' https://syrian-transit-system.vercel.app wss://syrian-transit-system.vercel.app https://*.supabase.co https://*.upstash.io; worker-src 'self' blob:; manifest-src 'self'; report-to default; report-uri /api/client_log"
        },
        { "key": "Report-To", "value": "{\"group\":\"default\",\"max_age\":10886400,\"endpoints\":[{\"url\":\"/api/client_log\"}],\"include_subdomains\":true}" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|webp|woff2|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/tiles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/simulate", "schedule": "0 0 * * *" }
  ],
  "env": {
    "ALLOWED_ORIGINS": "https://syrian-transit-system.vercel.app"
  }
}
