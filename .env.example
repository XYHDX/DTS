# Supabase (free tier: https://supabase.com)
# For 500-vehicle scale: use Supavisor pooler URL instead of the default project URL.
# Enable Supavisor in Supabase dashboard: Settings → Database → Connection Pooling.
# Pooler URL format: https://aws-0-<region>.pooler.supabase.com
# Default URL (max ~150 vehicles): https://your-project.supabase.co
SUPABASE_URL=https://aws-0-eu-central-1.pooler.supabase.com
SUPABASE_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# JWT Auth
JWT_SECRET=change-me-to-a-random-64-char-string

# CORS — comma-separated list of allowed origins. Wildcards (*) are rejected.
# Production: production domain only. Dev: add localhost origins as needed.
# VERCEL_ENV=production automatically strips localhost entries.
ALLOWED_ORIGINS=https://syrian-transit-system.vercel.app,https://syrian-transit-system-*.vercel.app,http://localhost:3000,http://localhost:8000

# Optional: Traccar webhook secret
TRACCAR_WEBHOOK_SECRET=optional-shared-secret

# Optional: Environment
ENVIRONMENT=production

# Optional: Resend email notifications (https://resend.com)
# Create a free account and add/verify a sending domain.
# Alert emails go to operators; welcome emails go to new users.
RESEND_API_KEY=re_...your-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com
# Comma-separated list of admin email addresses to receive critical alert emails
ALERT_EMAIL_RECIPIENTS=ops@yourdomain.com

# ── Scale track (Scale_100k_Roadmap.md) ──────────────────────────────────────
# Optional: Sentry release tag (step 80). Defaults to damascustransit@1.0.0.
APP_RELEASE=damascustransit@1.0.0

# S7.2 — expose Prometheus /metrics. Leave unset on Vercel (serverless); set to
# true on the Docker / self-hosted deployment scraped by docker-compose.scale.yml.
METRICS_ENABLED=false

# S2.2 — MQTT consumer (api/workers/mqtt_consumer.py). Used by the worker only.
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_STATUS_TOPIC=vehicles/+/status
MQTT_EVENT_TOPIC=vehicles/+/event

# S3.4 — live position bus for /api/stream (api/core/live_bus.py).
# Set REDIS_PUBSUB_URL to a TCP Redis to push SSE updates instead of polling the
# DB per client — this is what lets the stream scale horizontally without sticky
# sessions. Leave BOTH unset to keep the legacy poll path (default; unchanged on
# Vercel). LIVE_BUS_BACKEND=memory enables single-process fan-out with no Redis.
# REDIS_PUBSUB_URL=redis://localhost:6379/0
# LIVE_BUS_BACKEND=
# LIVE_BUS_QUEUE_MAXSIZE=256

# Grafana admin (docker-compose.scale.yml) — change before any non-local use.
GRAFANA_ADMIN_USER=admin
# REQUIRED for docker-compose.scale.yml — must be set; compose refuses to start if empty
GRAFANA_ADMIN_PASSWORD=

# ── Tenancy (2026-06-11 restructure) ─────────────────────────────
# Operator slug used to scope anonymous public reads (cross-tenant leak fix)
DEFAULT_OPERATOR_SLUG=damascus

# ── Sham Cash payments (scaffold) ────────────────────────────────
# sandbox (default, no credentials needed) | live
SHAM_CASH_MODE=sandbox
# Required only in live mode — issued by Sham Cash merchant services:
SHAM_CASH_MERCHANT_ID=
SHAM_CASH_API_SECRET=
SHAM_CASH_WEBHOOK_SECRET=
# Dedicated HMAC key for vehicle QR payloads (REQUIRED in live mode;
# sandbox derives a key from JWT_SECRET when unset)
QR_SIGNING_SECRET=
